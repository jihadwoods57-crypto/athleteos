# AthleteOS — Phase 2 backend (copy to `.env` and fill in to go live).
# With these UNSET, the app runs entirely on local mock data (isSupabaseConfigured=false).
# Both are safe to expose in a client bundle (the anon key is gated by Row-Level Security).
# Find them in your Supabase project: Settings -> API.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Real AI meal analysis (Claude vision). The app calls a backend Edge Function that holds
# the Anthropic key server-side; the KEY IS NEVER IN THE APP. With this unset, the app
# derives the endpoint from EXPO_PUBLIC_SUPABASE_URL (.../functions/v1/analyze-meal); set
# it explicitly only to point at a different endpoint. isAiConfigured = endpoint + anon key.
EXPO_PUBLIC_AI_ENDPOINT=

# The ANTHROPIC_API_KEY is a SERVER secret, NOT an EXPO_PUBLIC var. Set it on the backend:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   (optional) supabase secrets set ANTHROPIC_MODEL=claude-sonnet-4-6
