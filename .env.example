# AthleteOS — Phase 2 backend (copy to `.env` and fill in to go live).
# With these UNSET, the app runs entirely on local mock data (isSupabaseConfigured=false).
# Both are safe to expose in a client bundle (the anon key is gated by Row-Level Security).
# Find them in your Supabase project: Settings -> API.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
