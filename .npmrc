# React Native 0.86 (Expo SDK 57) declares an *optional* self-peer on
# @react-native/jest-preset that npm's strict resolver falsely flags as a
# conflict (ERESOLVE), even when every package agrees on 0.86.0. This is the
# Expo/RN-documented workaround and matches how RN app templates ship.
legacy-peer-deps=true
